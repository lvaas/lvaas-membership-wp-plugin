#!/bin/sh
# Re-set tracked files to umask-independent perms so the web server can serve
# static assets after `git pull` on hosts where the default umask (e.g. 0027)
# leaves new files mode 0640 / new dirs mode 0750. Skips .git and vendor —
# composer binaries may need exec bits we shouldn't clobber.
cd "$(git rev-parse --show-toplevel)" || exit 0
find . \( -path './.git' -o -path './vendor' \) -prune -o -type f -exec chmod 644 {} +
find . \( -path './.git' -o -path './vendor' \) -prune -o -type d -exec chmod 755 {} +
